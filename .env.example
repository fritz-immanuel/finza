# Required
TELEGRAM_BOT_TOKEN=your_token_here
MYSQL_DSN=user:password@tcp(localhost:3306)/moneytracker?parseTime=true&loc=UTC

# LLM
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash
LLM_CONFIDENCE_THRESHOLD=0.60

# Bot mode
BOT_MODE=polling

# Webhook (only if BOT_MODE=webhook)
BOT_WEBHOOK_URL=https://yourdomain.com
BOT_WEBHOOK_ADDR=:8443
BOT_WEBHOOK_PATH=/webhook
BOT_WEBHOOK_SECRET=random_secret_string

# Concurrency
BOT_WORKERS=4
BOT_QUEUE_SIZE=100

# Rate limiting
BOT_RATE_LIMIT_RPS=2
BOT_RATE_LIMIT_BURST=5

# Logging
BOT_DEBUG=false
